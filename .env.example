# ─── OpenRouter ────────────────────────────────────────────────────
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Vision model used for calorie analysis (supports image input)
OPENROUTER_VISION_MODEL=google/gemini-2.0-flash-001
# Fallback if primary model is unavailable
OPENROUTER_FALLBACK_MODEL=openai/gpt-4o-mini

# Text model for fake-news and health insights
OPENROUTER_TEXT_MODEL=google/gemini-2.0-flash-001

# ─── App ───────────────────────────────────────────────────────────
APP_NAME=SmartLens
DAILY_CALORIE_GOAL=2000
LOG_LEVEL=info
